{
  "name": "n8n-nodes-keenable",
  "version": "0.1.3",
  "description": "Keenable web search + page fetch nodes for n8n. Keyless by default (1,000 req/hour); an API key raises the limits.",
  "license": "MIT",
  "author": {
    "name": "Keenable",
    "url": "https://keenable.ai"
  },
  "homepage": "https://keenable.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/keenableai/n8n-nodes-keenable.git"
  },
  "bugs": {
    "url": "https://github.com/keenableai/n8n-nodes-keenable/issues"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "keenable",
    "web-search",
    "search",
    "fetch",
    "scraping",
    "ai-agent",
    "ai-tool"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/KeenableApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Keenable/Keenable.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && npm run build:assets",
    "build:assets": "mkdir -p dist/nodes/Keenable && cp nodes/Keenable/keenable.svg nodes/Keenable/Keenable.node.json dist/nodes/Keenable/",
    "check": "tsc --noEmit",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "format": "prettier nodes credentials --write",
    "prepublishOnly": "npm run build && eslint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.7",
    "n8n-workflow": "*",
    "prettier": "^3.8.4",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "form-data": "^4.0.6",
    "uuid": "^11.1.1"
  }
}
